{
  "name": "mafia-game",
  "version": "1.0.0",
  "description": "Multiplayer Mafia game — monorepo root",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "test": "npm run test --workspace=server && npm run test --workspace=client",
    "test:server": "npm run test --workspace=server",
    "test:client": "npm run test --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=shared && npm run build --workspace=server && npm run build --workspace=client",
    "multi-client": "scripts/multi-client.sh",
    "dev:backend": "scripts/dev-backend.sh",
    "simulate": "ts-node --transpile-only client/scripts/simulate-game.ts",
    "dev:party": "npm run dev:party --workspace=client",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.58.2"
  }
}
