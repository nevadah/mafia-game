{
  "name": "mafia-client",
  "version": "1.0.0",
  "description": "Mafia game Electron client",
  "main": "dist/main.js",
  "scripts": {
    "build:main": "tsc",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "start": "electron .",
    "dev": "npm run build && electron .",
    "dev:renderer": "vite",
    "dev:electron": "npm run build:main && ELECTRON_RENDERER_URL=http://localhost:5173 electron .",
    "dev:multi": "npm run build:main && MAFIA_MULTI_INSTANCE=1 electron .",
    "test": "jest --coverage",
    "test:integration": "jest --coverage --testPathPattern=integration",
    "test:renderer": "jest --config jest.renderer.config.js"
  },
  "dependencies": {
    "electron": "^27.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "@types/ws": "^8.5.9",
    "@vitejs/plugin-react": "^4.4.1",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "vite": "^5.4.14"
  }
}
